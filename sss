    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/penis.pt"
)

# ── Функция скачивания ──

function download_files() {
    local dir="$1"; shift
    local files=("$@")
    [[ $# -eq 0 ]] && return
    mkdir -p "$dir"
    for url in "${files[@]}"; do
        local auth_header=""
        if [[ -n "$HF_TOKEN" && "$url" =~ huggingface\.co ]]; then
            auth_header="--header=Authorization: Bearer $HF_TOKEN"
        fi
        wget $auth_header -nc --content-disposition --show-progress \
             -e dotbytes=4M -P "$dir" "$url" || true
    done
}

# ── Создаём папку SEEDVR2 (как было с Janus) ──

SEEDVR2_DIR="${COMFYUI_DIR}/models/SEEDVR2"
mkdir -p "${SEEDVR2_DIR}"

# ── Скачиваем модели ──

