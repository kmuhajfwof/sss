#!/bin/bash
set -e
source /venv/main/bin/activate

COMFYUI_DIR=/workspace/ComfyUI

# ── Модели (скачиваются с Hugging Face при старте) ────────────────

# --- Qwen-Image-Edit ---
DIFFUSION_MODELS=(
    "https://huggingface.co/lightx2v/Qwen-Image-Edit-2511-Lightning/resolve/main/qwen_image_edit_2511_fp8_e4m3fn_scaled_lightning_8steps_v1.0.safetensors"
    "https://huggingface.co/lightx2v/Qwen-Image-Edit-2511-Lightning/resolve/main/qwen_image_edit_2511_fp8_e4m3fn_scaled_lightning_comfyui_4steps_v1.0.safetensors"
    "https://huggingface.co/Comfy-Org/z_image/resolve/main/split_files/diffusion_models/z_image_bf16.safetensors"
    "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/diffusion_models/z_image_turbo_bf16.safetensors"
)

TEXT_ENCODERS=(
    "https://huggingface.co/Comfy-Org/Qwen-Image_ComfyUI/resolve/main/split_files/text_encoders/qwen_2.5_vl_7b_fp8_scaled.safetensors"
    "https://huggingface.co/Comfy-Org/z_image/resolve/main/split_files/text_encoders/qwen_3_4b.safetensors"
)

VAE_MODELS=(
    "https://huggingface.co/Comfy-Org/Qwen-Image_ComfyUI/resolve/main/split_files/vae/qwen_image_vae.safetensors"
    "https://huggingface.co/Comfy-Org/z_image/resolve/main/split_files/vae/ae.safetensors"
)

LORAS=(
    "https://huggingface.co/arhiteector/loras/resolve/main/experiment1/Z-Image-Banana%20V1%20-%20ZIB%2BZIT.safetensors"
    "https://huggingface.co/arhiteector/loras/resolve/main/billy/billy_base11_000000800.safetensors"
)

MODEL_PATCHES=(
    "https://huggingface.co/alibaba-pai/Z-Image-Fun-Controlnet-Union-2.1/resolve/main/Z-Image-Fun-Controlnet-Union-2.1.safetensors"
)

# --- Janus-Pro (git-lfs repo) ---
JANUS_REPO="https://huggingface.co/deepseek-ai/Janus-Pro-1B"
JANUS_DIR="${COMFYUI_DIR}/models/Janus-Pro/Janus-Pro-1B"

# ── Функция скачивания ──

function download_files() {
    local dir="$1"; shift
    local files=("$@")
    [[ $# -eq 0 ]] && return
    mkdir -p "$dir"
    for url in "${files[@]}"; do
        local auth_header=""
        if [[ -n "$HF_TOKEN" && "$url" =~ huggingface\.co ]]; then
            auth_header="--header=Authorization: Bearer $HF_TOKEN"
        fi
        wget $auth_header -nc --content-disposition --show-progress \
             -e dotbytes=4M -P "$dir" "$url" || true
    done
}

# ── Скачиваем модели ──

download_files "${COMFYUI_DIR}/models/diffusion_models"  "${DIFFUSION_MODELS[@]}"
download_files "${COMFYUI_DIR}/models/text_encoders"     "${TEXT_ENCODERS[@]}"
download_files "${COMFYUI_DIR}/models/vae"               "${VAE_MODELS[@]}"
download_files "${COMFYUI_DIR}/models/loras"             "${LORAS[@]}"
download_files "${COMFYUI_DIR}/models/model_patches"     "${MODEL_PATCHES[@]}"

# ── Клонируем Janus-Pro (нужен git-lfs) ──

if [[ ! -d "${JANUS_DIR}" ]]; then
    echo "📦 Cloning Janus-Pro-1B..."
    mkdir -p "$(dirname "${JANUS_DIR}")"
    git lfs install
    git clone "${JANUS_REPO}" "${JANUS_DIR}"
else
    echo "✅ Janus-Pro-1B already exists, skipping"
fi

echo "✅ All models downloaded"
