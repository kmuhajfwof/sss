FROM vastai/comfy:v0.10.0-cuda-12.9-py312

# Activate venv
ENV VIRTUAL_ENV=/venv/main
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"

ENV COMFYUI_DIR=/workspace/ComfyUI

# ── 1. System packages ──
RUN apt-get update && apt-get install -y --no-install-recommends git-lfs && \
    git lfs install && \
    rm -rf /var/lib/apt/lists/*

# ── 2. Clone ComfyUI into /workspace ──
RUN mkdir -p /workspace && \
    git clone https://github.com/comfyanonymous/ComfyUI.git "${COMFYUI_DIR}" && \
    cd "${COMFYUI_DIR}" && \
    pip install --no-cache-dir -r requirements.txt

# ── 3. Clone custom nodes (split to handle large repos) ──
RUN cd "${COMFYUI_DIR}/custom_nodes" && \
    git clone --recursive https://github.com/rgthree/rgthree-comfy && \
    git clone --recursive https://github.com/kijai/ComfyUI-KJNodes && \
    git clone --recursive https://github.com/Suzie1/ComfyUI_Comfyroll_CustomNodes && \
    git clone --recursive https://github.com/ltdrdata/ComfyUI-Impact-Pack && \
    git clone --recursive https://github.com/Fannovel16/comfyui_controlnet_aux && \
    git clone --recursive https://github.com/pythongosssss/ComfyUI-Custom-Scripts && \
    git clone --recursive https://github.com/yolain/ComfyUI-Easy-Use && \
    git clone --recursive https://github.com/CY-CHENYUE/ComfyUI-Janus-Pro && \
    git clone --recursive https://github.com/WASasquatch/was-node-suite-comfyui && \
    git clone --recursive https://github.com/nkchocoai/ComfyUI-PromptUtilities && \
    git clone --recursive https://github.com/ltdrdata/ComfyUI-Inspire-Pack && \
    git clone --recursive https://github.com/crystian/ComfyUI-Crystools && \
    git clone --recursive https://github.com/cubiq/ComfyUI_essentials && \
    git clone --recursive https://github.com/evanspearman/ComfyMath && \
    git clone --recursive https://github.com/kmuhajfwof/tsutils2 && \
    git clone --recursive https://github.com/Comfy-Org/ComfyUI-Manager

# RES4LYF is large — clone separately with increased git buffer
RUN cd "${COMFYUI_DIR}/custom_nodes" && \
    git config --global http.postBuffer 524288000 && \
    git clone --recursive https://github.com/ClownsharkBatwing/RES4LYF

# ── 4. Install pip requirements for every custom node ──
RUN cd "${COMFYUI_DIR}/custom_nodes" && \
    for dir in */; do \
        if [ -f "${dir}requirements.txt" ]; then \
            echo "Installing requirements for ${dir}..." && \
            pip install --no-cache-dir -r "${dir}requirements.txt" || true; \
        fi; \
    done

# ── 5. Pre-create model directories ──
RUN mkdir -p "${COMFYUI_DIR}/models/clip" \
             "${COMFYUI_DIR}/models/clip_vision" \
             "${COMFYUI_DIR}/models/text_encoders" \
             "${COMFYUI_DIR}/models/vae" \
             "${COMFYUI_DIR}/models/diffusion_models" \
             "${COMFYUI_DIR}/models/controlnet" \
             "${COMFYUI_DIR}/models/detection" \
             "${COMFYUI_DIR}/models/loras" \
             "${COMFYUI_DIR}/models/model_patches" \
             "${COMFYUI_DIR}/models/upscale_models" \
             "${COMFYUI_DIR}/models/Janus-Pro"
