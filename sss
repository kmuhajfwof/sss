DIFFUSION_MODELS=(
    "https://huggingface.co/Comfy-Org/Qwen-Image-Edit_ComfyUI/resolve/main/split_files/diffusion_models/qwen_image_edit_2511_bf16.safetensors"
    "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/diffusion_models/z_image_turbo_bf16.safetensors"
)

TEXT_ENCODERS=(
    "https://huggingface.co/Comfy-Org/Qwen-Image_ComfyUI/resolve/main/split_files/text_encoders/qwen_2.5_vl_7b_fp8_scaled.safetensors"
    "https://huggingface.co/Comfy-Org/z_image/resolve/main/split_files/text_encoders/qwen_3_4b.safetensors"
)

VAE_MODELS=(
    "https://huggingface.co/Comfy-Org/Qwen-Image_ComfyUI/resolve/main/split_files/vae/qwen_image_vae.safetensors"
    "https://huggingface.co/Comfy-Org/z_image/resolve/main/split_files/vae/ae.safetensors"
)

LORAS=(
    "https://huggingface.co/lightx2v/Qwen-Image-Edit-2511-Lightning/resolve/main/Qwen-Image-Edit-2511-Lightning-8steps-V1.0-fp32.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/qwen-image_nsfw_adv_v1.0.safetensors"
    "https://huggingface.co/prithivMLmods/Qwen-Image-Edit-2511-Unblur-Upscale/resolve/main/Qwen-Image-Edit-Unblur-Upscale_20.safetensors"
    "https://huggingface.co/arhiteector/loras/resolve/main/billy/billy_base11_000000800.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/Z-TURBO_Photography_35mmPhoto_896.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/afterdark_z_image_turbo.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/b3tternud3s_v2.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/lenovo_z.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/movie_zimage_lora.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/nicegirls_Zimage.safetensors"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/psxZStyle_v1_ZIT.safetensors"
)

MODEL_PATCHES=(
)

# --- SAM ---
SAM_MODELS=(
    "https://huggingface.co/datasets/Gourieff/ReActor/resolve/main/models/sams/sam_vit_b_01ec64.pth"
)

# --- Ultralytics bbox models ---
ULTRALYTICS_BBOX_MODELS=(
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/Eyeful_v2-Paired.pt"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/Face.pt"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/Nipples.pt"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/Pussy.pt"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/penis.pt"
    "https://huggingface.co/arhiteector/zimageqwen/resolve/main/detectionmodels/vagina-v3.2.pt"
)

# --- Janus-Pro (git-lfs repo) ---
JANUS_REPO="https://huggingface.co/deepseek-ai/Janus-Pro-1B"
JANUS_DIR="${COMFYUI_DIR}/models/Janus-Pro/Janus-Pro-1B"

# ── Функция скачивания ──

function download_files() {
    local dir="$1"; shift
    local files=("$@")
    [[ $# -eq 0 ]] && return
    mkdir -p "$dir"
    for url in "${files[@]}"; do
        local auth_header=""
        if [[ -n "$HF_TOKEN" && "$url" =~ huggingface\.co ]]; then
            auth_header="--header=Authorization: Bearer $HF_TOKEN"
        fi
        wget $auth_header -nc --content-disposition --show-progress \
             -e dotbytes=4M -P "$dir" "$url" || true
    done
}

# ── Скачиваем модели ──

download_files "${COMFYUI_DIR}/models/diffusion_models"     "${DIFFUSION_MODELS[@]}"
download_files "${COMFYUI_DIR}/models/text_encoders"        "${TEXT_ENCODERS[@]}"
download_files "${COMFYUI_DIR}/models/vae"                  "${VAE_MODELS[@]}"
download_files "${COMFYUI_DIR}/models/loras"                "${LORAS[@]}"
download_files "${COMFYUI_DIR}/models/model_patches"        "${MODEL_PATCHES[@]}"
download_files "${COMFYUI_DIR}/models/sams"                 "${SAM_MODELS[@]}"
download_files "${COMFYUI_DIR}/models/ultralytics/bbox"     "${ULTRALYTICS_BBOX_MODELS[@]}"

# ── Клонируем Janus-Pro (нужен git-lfs) ──

if [[ ! -d "${JANUS_DIR}" ]]; then
    echo "📦 Cloning Janus-Pro-1B..."
    mkdir -p "$(dirname "${JANUS_DIR}")"
    git lfs install
    git clone "${JANUS_REPO}" "${JANUS_DIR}"
else
    echo "✅ Janus-Pro-1B already exists, skipping"
fi

echo "✅ All models downloaded"
